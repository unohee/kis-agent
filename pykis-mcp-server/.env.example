# 한국투자증권 OpenAPI 인증 정보
# https://apiportal.koreainvestment.com 에서 발급

# APP KEY (필수)
KIS_APP_KEY=YOUR_APP_KEY_HERE

# APP SECRET (필수)
KIS_SECRET=YOUR_SECRET_HERE

# 계좌 정보 (필수)
KIS_ACCOUNT_NO=YOUR_ACCOUNT_NUMBER

# 계좌 상품 코드 (기본값: 01)
# 01: 종합계좌
KIS_ACCOUNT_CODE=01

# MCP Server 설정 (선택)
# 모의투자 URL (개발용)
# KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# Rate Limiting (선택)
ENABLE_RATE_LIMITER=true
REQUESTS_PER_SECOND=18
REQUESTS_PER_MINUTE=900

# Cache (선택)
ENABLE_CACHE=true
DEFAULT_CACHE_TTL=5

# Logging (선택)
LOG_LEVEL=INFO
